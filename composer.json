{
    "name": "creagia/laravel-web-mailer",
    "description": "Laravel Web Mailer",
    "keywords": [
        "creagia",
        "laravel",
        "laravel-web-mailer",
        "mail"
    ],
    "homepage": "https://github.com/creagia/laravel-web-mailer",
    "license": "MIT",
    "authors": [
        {
            "name": "Xavier Muntané",
            "email": "xavier@creagia.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "spatie/laravel-package-tools": "^1.9.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "symfony/mime": "^7.0|^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.8",
        "nunomaduro/collision": "^8.0",
        "nunomaduro/larastan": "^3.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.7|^4.4.1",
        "pestphp/pest-plugin-laravel": "^3.1|^4.1",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.5.3|^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "Creagia\\LaravelWebMailer\\": "src",
            "Creagia\\LaravelWebMailer\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Creagia\\LaravelWebMailer\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Creagia\\LaravelWebMailer\\LaravelWebMailerServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
